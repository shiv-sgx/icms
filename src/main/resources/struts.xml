<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.0//EN"
    "/WEB-INF/classes/struts-2.1.7.dtd">

<struts>

    <!-- Production default. Flip to true (here or in struts.properties) for local dev. -->
    <constant name="struts.devMode" value="false" />
    <!-- Use the 'simple' theme so our Struts2 tags emit clean markup we style ourselves. -->
    <constant name="struts.ui.theme" value="simple" />
    <!-- Cap multipart uploads (claim documents) at 10MB. -->
    <constant name="struts.multipart.maxSize" value="10485760" />

    <!-- =====================================================================
         Base package: shared interceptors, global results, exception mapping.
         Extends tiles-default (from struts2-tiles-plugin) so results can use
         type="tiles". Abstract: only extended, never mapped directly.
         ===================================================================== -->
    <package name="icms-base" extends="tiles-default" abstract="true">

        <interceptors>
            <interceptor name="auth"
                class="com.sgx.icms.web.interceptor.AuthInterceptor" />
            <interceptor name="role"
                class="com.sgx.icms.web.interceptor.RoleInterceptor" />

            <!-- Authenticated + authorised stack for the role portals. -->
            <interceptor-stack name="secured">
                <interceptor-ref name="defaultStack" />
                <interceptor-ref name="auth" />
                <interceptor-ref name="role" />
            </interceptor-stack>
        </interceptors>

        <global-results>
            <result name="login" type="redirect">/login</result>
            <result name="denied" type="tiles">denied</result>
            <result name="error" type="tiles">error</result>
        </global-results>

        <global-exception-mappings>
            <exception-mapping exception="java.lang.Exception" result="error" />
        </global-exception-mappings>
    </package>

    <!-- Abstract package that defaults every action to the secured stack. -->
    <package name="icms-secured" extends="icms-base" abstract="true">
        <default-interceptor-ref name="secured" />
    </package>

    <!-- =====================================================================
         Public area (no authentication): login, logout, landing.
         ===================================================================== -->
    <package name="public" extends="icms-base" namespace="/">

        <default-action-ref name="index" />

        <action name="index">
            <result type="redirect">/login</result>
        </action>

        <!-- GET: render the login form (no processing). -->
        <action name="login">
            <result type="tiles">login</result>
        </action>

        <!-- POST: authenticate, then redirect to the role dashboard. -->
        <action name="doLogin"
                class="com.sgx.icms.web.action.auth.LoginAction">
            <result name="success" type="redirect">${redirectUrl}</result>
            <result name="input" type="tiles">login</result>
        </action>

        <action name="logout"
                class="com.sgx.icms.web.action.auth.LogoutAction">
            <result name="success" type="redirect">/login</result>
        </action>

        <!-- FAQ / help: public, rendered within the app layout. -->
        <action name="faq" class="com.sgx.icms.web.action.FaqAction">
            <result type="tiles">faq</result>
        </action>
    </package>

    <!-- =====================================================================
         Role portals — each namespace guarded by the secured stack, which the
         RoleInterceptor maps to the matching role.
         ===================================================================== -->
    <package name="customer" extends="icms-secured" namespace="/customer">

        <global-results>
            <result name="missing" type="redirect">/customer/claims</result>
        </global-results>

        <action name="dashboard"
                class="com.sgx.icms.web.action.customer.CustomerDashboardAction">
            <result type="tiles">customer.dashboard</result>
        </action>

        <action name="claims"
                class="com.sgx.icms.web.action.customer.ClaimListAction">
            <result type="tiles">customer.claims</result>
        </action>

        <action name="claim"
                class="com.sgx.icms.web.action.customer.ClaimDetailAction">
            <result type="tiles">customer.claim</result>
        </action>

        <!-- New claim: GET shows the form, POST creates it. -->
        <action name="newClaim"
                class="com.sgx.icms.web.action.customer.NewClaimAction" method="show">
            <result name="input" type="tiles">customer.newClaim</result>
        </action>
        <action name="createClaim"
                class="com.sgx.icms.web.action.customer.NewClaimAction">
            <result name="success" type="redirect">${redirectUrl}</result>
            <result name="input" type="tiles">customer.newClaim</result>
        </action>

        <action name="uploadDocument"
                class="com.sgx.icms.web.action.customer.DocumentUploadAction">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>

        <action name="message"
                class="com.sgx.icms.web.action.customer.MessageAction">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>

        <action name="withdraw"
                class="com.sgx.icms.web.action.customer.WithdrawAction">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>

        <action name="profile"
                class="com.sgx.icms.web.action.customer.ProfileAction">
            <result type="tiles">customer.profile</result>
        </action>
    </package>

    <package name="agent" extends="icms-secured" namespace="/agent">

        <global-results>
            <result name="missing" type="redirect">/agent/claims</result>
        </global-results>

        <action name="dashboard"
                class="com.sgx.icms.web.action.agent.AgentDashboardAction">
            <result type="tiles">agent.dashboard</result>
        </action>

        <action name="claims"
                class="com.sgx.icms.web.action.agent.AgentClaimListAction">
            <result type="tiles">agent.claims</result>
        </action>

        <action name="claim"
                class="com.sgx.icms.web.action.agent.AgentClaimDetailAction">
            <result type="tiles">agent.claim</result>
        </action>

        <!-- claim-detail POST actions (DMI disabled: explicit method per mapping) -->
        <action name="acknowledge"
                class="com.sgx.icms.web.action.agent.AgentClaimActionsAction" method="acknowledge">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="assignSurveyor"
                class="com.sgx.icms.web.action.agent.AgentClaimActionsAction" method="assign">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="forward"
                class="com.sgx.icms.web.action.agent.AgentClaimActionsAction" method="forward">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="saveNote"
                class="com.sgx.icms.web.action.agent.AgentClaimActionsAction" method="note">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="message"
                class="com.sgx.icms.web.action.agent.AgentClaimActionsAction" method="message">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>

        <!-- settlement screen -->
        <action name="settlement"
                class="com.sgx.icms.web.action.agent.SettlementAction" method="show">
            <result type="tiles">agent.settlement</result>
        </action>
        <action name="processSettlement"
                class="com.sgx.icms.web.action.agent.SettlementAction" method="process">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="advanceSettlement"
                class="com.sgx.icms.web.action.agent.SettlementAction" method="advance">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>

        <action name="communications"
                class="com.sgx.icms.web.action.agent.AgentCommunicationsAction">
            <result type="tiles">agent.communications</result>
        </action>
    </package>

    <package name="surveyor" extends="icms-secured" namespace="/surveyor">

        <global-results>
            <result name="missing" type="redirect">/surveyor/dashboard</result>
        </global-results>

        <action name="dashboard"
                class="com.sgx.icms.web.action.surveyor.SurveyorDashboardAction">
            <result type="tiles">surveyor.dashboard</result>
        </action>

        <action name="assess"
                class="com.sgx.icms.web.action.surveyor.AssessAction" method="show">
            <result type="tiles">surveyor.assess</result>
        </action>
        <action name="submitAssessment"
                class="com.sgx.icms.web.action.surveyor.AssessAction" method="submit">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="uploadReport"
                class="com.sgx.icms.web.action.surveyor.AssessAction" method="upload">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
    </package>

    <package name="manager" extends="icms-secured" namespace="/manager">

        <global-results>
            <result name="missing" type="redirect">/manager/approvals</result>
        </global-results>

        <action name="dashboard"
                class="com.sgx.icms.web.action.manager.ManagerDashboardAction">
            <result type="tiles">manager.dashboard</result>
        </action>

        <action name="approvals"
                class="com.sgx.icms.web.action.manager.ApprovalQueueAction">
            <result type="tiles">manager.approvals</result>
        </action>

        <action name="claim"
                class="com.sgx.icms.web.action.manager.ManagerClaimDetailAction">
            <result type="tiles">manager.claim</result>
        </action>

        <action name="decide"
                class="com.sgx.icms.web.action.manager.DecisionAction" method="decide">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="overrideSettlement"
                class="com.sgx.icms.web.action.manager.DecisionAction" method="override">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>

        <action name="reports"
                class="com.sgx.icms.web.action.manager.ReportsAction">
            <result type="tiles">manager.reports</result>
        </action>
        <!-- CSV download: writes to the response and returns NONE (no result). -->
        <action name="exportReport"
                class="com.sgx.icms.web.action.manager.ReportExportAction" />
    </package>

    <package name="admin" extends="icms-secured" namespace="/admin">

        <global-results>
            <result name="missing" type="redirect">/admin/dashboard</result>
        </global-results>

        <action name="dashboard"
                class="com.sgx.icms.web.action.admin.AdminDashboardAction">
            <result type="tiles">admin.dashboard</result>
        </action>

        <!-- User management -->
        <action name="users"
                class="com.sgx.icms.web.action.admin.UserAdminAction" method="list">
            <result type="tiles">admin.users</result>
        </action>
        <action name="createUser"
                class="com.sgx.icms.web.action.admin.UserAdminAction" method="create">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="updateUser"
                class="com.sgx.icms.web.action.admin.UserAdminAction" method="update">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="resetPassword"
                class="com.sgx.icms.web.action.admin.UserAdminAction" method="resetPassword">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>

        <action name="roles"
                class="com.sgx.icms.web.action.admin.RolesAction">
            <result type="tiles">admin.roles</result>
        </action>

        <!-- Configuration -->
        <action name="sla"
                class="com.sgx.icms.web.action.admin.ConfigAction" method="sla">
            <result type="tiles">admin.sla</result>
        </action>
        <action name="updateSla"
                class="com.sgx.icms.web.action.admin.ConfigAction" method="updateSla">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="thresholds"
                class="com.sgx.icms.web.action.admin.ConfigAction" method="thresholds">
            <result type="tiles">admin.thresholds</result>
        </action>
        <action name="updateThreshold"
                class="com.sgx.icms.web.action.admin.ConfigAction" method="updateThreshold">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="templates"
                class="com.sgx.icms.web.action.admin.ConfigAction" method="templates">
            <result type="tiles">admin.templates</result>
        </action>
        <action name="updateTemplate"
                class="com.sgx.icms.web.action.admin.ConfigAction" method="updateTemplate">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="documents"
                class="com.sgx.icms.web.action.admin.ConfigAction" method="documents">
            <result type="tiles">admin.documents</result>
        </action>
        <action name="addDocument"
                class="com.sgx.icms.web.action.admin.ConfigAction" method="addDocument">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>
        <action name="deleteDocument"
                class="com.sgx.icms.web.action.admin.ConfigAction" method="deleteDocument">
            <result name="success" type="redirect">${redirectUrl}</result>
        </action>

        <!-- Audit -->
        <action name="audit"
                class="com.sgx.icms.web.action.admin.AuditAction">
            <result type="tiles">admin.audit</result>
        </action>
        <action name="exportAudit"
                class="com.sgx.icms.web.action.admin.AuditExportAction" />
    </package>

</struts>
