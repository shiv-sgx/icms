<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE log4j:configuration PUBLIC "-//log4j/log4j Configuration//EN" "log4j.dtd">

<log4j:configuration xmlns:log4j="http://jakarta.apache.org/log4j/">

    <appender name="STDOUT" class="org.apache.log4j.ConsoleAppender">
       <layout class="org.apache.log4j.PatternLayout">
          <!-- [%X{cid}] is the per-request correlation id set by CorrelationIdFilter. -->
          <param name="ConversionPattern" value="%d %-5p [%X{cid}] %c.%M:%L - %m%n"/>
       </layout>
    </appender>

    <!-- Framework libraries: keep quiet in production. -->
    <logger name="com.opensymphony">
        <level value="WARN" />
    </logger>
    <logger name="org.apache.struts2">
        <level value="WARN" />
    </logger>
    <logger name="org.apache.tiles">
        <level value="WARN" />
    </logger>
    <logger name="com.zaxxer.hikari">
        <level value="INFO" />
    </logger>

    <!-- Our application: INFO. -->
    <logger name="com.sgx.icms">
        <level value="INFO" />
    </logger>

    <root>
        <priority value="INFO"/>
        <appender-ref ref="STDOUT" />
    </root>

</log4j:configuration>
