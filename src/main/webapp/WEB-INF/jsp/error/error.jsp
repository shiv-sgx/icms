<%@ page contentType="text/html;charset=UTF-8" pageEncoding="UTF-8" %>
<%@ taglib prefix="s" uri="/struts-tags" %>

<div class="login-card">
    <h1 class="login-title">Something went wrong</h1>
    <p class="login-hint">An unexpected error occurred. The team has been notified. Please try again.</p>
    <s:a action="login" namespace="/" cssClass="btn btn-primary btn-block">Back to sign in</s:a>
</div>
