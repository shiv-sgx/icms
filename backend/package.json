{
  "name": "icms-backend",
  "version": "1.0.0",
  "description": "ICMS REST API — Node/Express + Knex over the existing MySQL database (migration from Struts 2).",
  "type": "commonjs",
  "main": "src/server.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
